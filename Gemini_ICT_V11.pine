//@version=5
strategy("Gemini ICT V11 [Extended Dashboard - FINAL]", overlay=true, initial_capital=10000, default_qty_type=strategy.cash, default_qty_value=10000, currency=currency.USD)

// --- 1. BEÁLLÍTÁSOK ---
group_risk   = "Kockázatkezelés"
riskPerTrade = input.float(2.0, title="Kockázat / Trade (%)", minval=0.1, step=0.1, group=group_risk)
riskReward   = input.float(2.0, title="Risk : Reward Arány", group=group_risk)
stopPoints   = input.float(3.0, title="Fix Stop Buffer (Pont)", group=group_risk)

group_time   = "Időzítés"
sessionInput = input.session("0930-1030", title="Kereskedési Sáv (NY Idő)", group=group_time)

group_logic  = "Logika (V9 Alap)"
atrLength    = input.int(14, title="ATR Hossz", group=group_logic)
dispMult     = input.float(0.6, title="Displacement Erősség", group=group_logic) 
sweepLookback= input.int(5, title="Sweep Visszatekintés", group=group_logic)
useStrictFVG = input.bool(false, title="Szigorú FVG?", group=group_logic)

// --- 2. ADATOK ---
inSession = time(timeframe.period, sessionInput + ":1234567", "America/New_York")
bgcolor(inSession ? color.new(color.blue, 90) : na)

atrVal = ta.atr(atrLength)

// Változók a Dashboardhoz
var float dash_entry = na
var float dash_sl    = na
var float dash_tp    = na
var string dash_dir  = "NONE"

// --- 3. LOGIKA ---
isBigBody = math.abs(close - open) > (atrVal * dispMult)

highestHigh = ta.highest(high, sweepLookback)[1]
lowestLow   = ta.lowest(low, sweepLookback)[1]
wasSweepHigh = ta.highest(high, 3) > highestHigh
wasSweepLow  = ta.lowest(low, 3) < lowestLow

// FVG
bullFVG_Strict = (low[0] > high[2]) 
bearFVG_Strict = (high[0] < low[2])
isBullValid = useStrictFVG ? bullFVG_Strict : (close > open)
isBearValid = useStrictFVG ? bearFVG_Strict : (close < open)

longCondition = inSession and close > open and isBigBody and wasSweepLow and isBullValid
shortCondition = inSession and close < open and isBigBody and wasSweepHigh and isBearValid

// --- 4. POZÍCIÓMÉRET (Vantage Safe) ---
calcSafeQty(stopDistance) =>
    if stopDistance == 0
        0
    else
        float riskAmount = strategy.equity * (riskPerTrade / 100)
        float rawQty = riskAmount / stopDistance
        // Lefelé kerekítés egész számra, hogy a bróker elfogadja
        int safeQty = int(math.floor(rawQty))
        safeQty

// --- 5. VÉGREHAJTÁS ---
if (longCondition)
    float slPrice = low - stopPoints
    float entryPrice = close
    float stopDist = entryPrice - slPrice
    float tpPrice = entryPrice + (stopDist * riskReward)
    
    // Dashboard mentés
    dash_entry := entryPrice
    dash_sl    := slPrice
    dash_tp    := tpPrice
    dash_dir   := "LONG"
    
    int qty = calcSafeQty(stopDist)
    
    if qty > 0
        strategy.entry("Long", strategy.long, qty=qty, comment="Risk 2%")
        strategy.exit("Exit", "Long", stop=slPrice, limit=tpPrice)

if (shortCondition)
    float slPrice = high + stopPoints
    float entryPrice = close
    float stopDist = slPrice - entryPrice
    float tpPrice = entryPrice - (stopDist * riskReward)
    
    // Dashboard mentés
    dash_entry := entryPrice
    dash_sl    := slPrice
    dash_tp    := tpPrice
    dash_dir   := "SHORT"
    
    int qty = calcSafeQty(stopDist)
    
    if qty > 0
        strategy.entry("Short", strategy.short, qty=qty, comment="Risk 2%")
        strategy.exit("Exit", "Short", stop=slPrice, limit=tpPrice)

// --- 6. DASHBOARD ---
var table statusTable = table.new(position.bottom_right, 2, 8, border_width=1, bgcolor=color.new(color.black, 50))
if barstate.islast
    table.cell(statusTable, 0, 0, "GEMINI V11 [FINAL]", text_color=color.white, bgcolor=color.blue)
    
    table.cell(statusTable, 0, 1, "Equity", text_color=color.white)
    table.cell(statusTable, 1, 1, str.tostring(strategy.equity, "#.##"), text_color=color.green)
    
    table.cell(statusTable, 0, 2, "Net Profit", text_color=color.white)
    table.cell(statusTable, 1, 2, str.tostring(strategy.netprofit, "#.##"), text_color=strategy.netprofit >= 0 ? color.green : color.red)

    table.cell(statusTable, 0, 3, "--- LAST TRADE ---", text_color=color.gray, bgcolor=color.black)
    table.cell(statusTable, 1, 3, dash_dir, text_color=dash_dir == "LONG" ? color.green : (dash_dir == "SHORT" ? color.red : color.gray), bgcolor=color.black)

    table.cell(statusTable, 0, 4, "Entry Price", text_color=color.white)
    table.cell(statusTable, 1, 4, str.tostring(dash_entry, "#.##"), text_color=color.blue)

    table.cell(statusTable, 0, 5, "Take Profit", text_color=color.white)
    table.cell(statusTable, 1, 5, str.tostring(dash_tp, "#.##"), text_color=color.green)

    table.cell(statusTable, 0, 6, "Stop Loss", text_color=color.white)
    table.cell(statusTable, 1, 6, str.tostring(dash_sl, "#.##"), text_color=color.red)
    
    table.cell(statusTable, 0, 7, "Win Rate", text_color=color.white)
    float wr = strategy.closedtrades > 0 ? (strategy.wintrades / strategy.closedtrades * 100) : 0
    table.cell(statusTable, 1, 7, str.tostring(wr, "#.1") + "%", text_color=color.orange)
